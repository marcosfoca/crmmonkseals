# ── Supabase ────────────────────────────────────────────────
# Copia del dashboard: Settings → API
VITE_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Service role key (solo backend, NUNCA exponer en frontend)
SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── Auth JWT ─────────────────────────────────────────────────
# Genera una cadena aleatoria larga (ej: openssl rand -hex 32)
JWT_SECRET=cambia_esto_por_una_cadena_muy_larga_y_segura

# ── Gemini AI (para Scanner de formularios) ──────────────────
# https://aistudio.google.com/app/apikey  (gratis)
GEMINI_API_KEY=AIza...
